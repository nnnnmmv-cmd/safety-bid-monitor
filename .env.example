# 알림 채널 선택:
#   - SLACK_WEBHOOK_URL이 채워져 있으면 Slack으로 발송 (우선)
#   - 비어 있으면 SMTP(이메일)로 발송
#   - 둘 다 비어 있으면 콘솔 로그에만 남김

# ----- Slack -----
# https://api.slack.com/apps 에서 만든 Incoming Webhook URL
SLACK_WEBHOOK_URL=
# 에러 알림을 다른 채널로 보내고 싶을 때만 채움 (비우면 위 URL 재사용)
SLACK_ADMIN_WEBHOOK_URL=

# ----- 이메일 (Slack을 안 쓸 때만 채우면 됨) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
NOTIFY_TO=
NOTIFY_ADMIN=

# ----- 동작 옵션 -----
LOOKBACK_HOURS=48
REQUEST_DELAY_SEC=1.0
HTTP_TIMEOUT_SEC=15
