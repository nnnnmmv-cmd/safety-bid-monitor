<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.safetybid.monitor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd "/Users/dev06/Safety diagnosis bid" &amp;&amp; ./.venv/bin/python -m src.monitor</string>
