<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.safetybid.healthcheck</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd "/Users/dev06/Safety diagnosis bid" &amp;&amp; ./.venv/bin/python scripts/healthcheck.py --full --slack &gt;&gt; logs/healthcheck.log 2&gt;&amp;1</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/dev06/Safety diagnosis bid</string>

    <!-- 매일 KST 08:00 — monitor cron(09:05) 1시간 전 사전 점검 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/dev06/Safety diagnosis bid/logs/healthcheck.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/dev06/Safety diagnosis bid/logs/healthcheck.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>LANG</key>
        <string>ko_KR.UTF-8</string>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>
</dict>
</plist>
